      "depends_on": ["torso"],
      "context": "大腿粗细需对齐躯干髋宽；小腿衔接大腿；脚部对齐小腿。同级内左侧优先保证对称。" },
    { "stage": 3, "name": "upper_limbs", "label": "上肢 (L→R)",
      "parts": ["upper_arm_L", "upper_arm_R", "forearm_L", "forearm_R", "hand_L", "hand_R"],
      "depends_on": ["torso"],
      "context": "上臂需对齐躯干肩宽；前臂衔接上臂；手部衔接前臂。同级内左侧优先保证对称。" },
    { "stage": 4, "name": "head",        "label": "头部",
      "parts": ["head"],
      "depends_on": ["torso"],
      "context": "头部大小需与躯干比例协调 (约1:7头身)。发型/瞳色与全局图一致。" },
    { "stage": 5, "name": "expressions", "label": "表情 (基于头部)",
      "parts": ["expr_happy_eyes", "expr_closed_eyes", "expr_smile_mouth", "expr_surprised_mouth"],
      "depends_on": ["head"],
      "context": "眼睛/嘴部需与头部脸型、五官位置对齐。瞳色与head阶段一致，表情夸张度适中。" }
  ],
